{
	"name": "saishumin",
	"description": "A browser game built with Effect, lit-html, and Otaku.",
	"scripts": {
		"build": "bun scripts/build.ts",
		"dev": "bun --hot index.html",
		"test": "bun test",
		"typecheck": "tsc",
		"check": "bun --bun biome check --write",
		"otaku:update": "git submodule update --init vendor/otaku",
		"references:update": "git submodule update --init --recursive reference_repositories/effect-smol reference_repositories/mattpocock-skills",
		"prepare": "effect-tsgo patch",
		"chore:update": "bun update --latest && bun add effect@beta"
	},
	"dependencies": {
		"effect": "^4.0.0-beta.97",
		"lit-html": "^3.3.3",
		"otaku-hmr": "file:vendor/otaku/packages/otaku-hmr",
		"otaku-state": "file:vendor/otaku/packages/otaku-state"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@effect/tsgo": "^0.19.0",
		"@types/bun": "^1.3.14",
		"tailwindcss": "4.3.2",
		"tailwindcss-bun-plugin": "^4.3.1",
		"typescript": "^7.0.2"
	}
}
